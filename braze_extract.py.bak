#!/usr/bin/env python3
"""
braze_extract.py
================
Pulls Canvas + Campaign analytics from Braze REST API and stores them in:
  - braze_metrics.db     (SQLite, normalized)
  - dashboard_data.json  (denormalized — what the HTML dashboard reads)

Run daily via cron / GitHub Actions / Devin schedule.

Required env vars:
  BRAZE_API_KEY       Braze REST API key with canvas.* and campaigns.* read scopes
  BRAZE_REST_ENDPOINT e.g. https://rest.iad-05.braze.com
                      (find yours at https://www.braze.com/docs/api/basics/#endpoints)

Optional env vars:
  BRAZE_DAYS          How many days of history to pull (default 30)
  BRAZE_TAG           Only extract flows with this tag
  BRAZE_OUT_DIR       Output directory (default ./out)
  BRAZE_SKIP_CAMPAIGNS=1   Skip Campaigns (only extract Canvases)
  BRAZE_SKIP_CANVASES=1    Skip Canvases (only extract Campaigns)
"""

from __future__ import annotations

import json
import os
import sqlite3
import sys
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any, Iterable

import requests

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

API_KEY = os.environ.get("BRAZE_API_KEY", "").strip()
ENDPOINT = os.environ.get("BRAZE_REST_ENDPOINT", "").strip().rstrip("/")
DAYS = int(os.environ.get("BRAZE_DAYS", "30"))
TAG_FILTER = os.environ.get("BRAZE_TAG", "").strip() or None
OUT_DIR = Path(os.environ.get("BRAZE_OUT_DIR", "./out")).resolve()
SKIP_CAMPAIGNS = os.environ.get("BRAZE_SKIP_CAMPAIGNS", "").lower() in ("1", "true", "yes")
SKIP_CANVASES = os.environ.get("BRAZE_SKIP_CANVASES", "").lower() in ("1", "true", "yes")

CANVAS_MAX_DAYS = 14
CAMPAIGN_MAX_DAYS = 100
SLEEP_BETWEEN_CALLS = 0.5


def fail(msg: str) -> None:
    print(f"ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


if not API_KEY:
    fail("BRAZE_API_KEY env var is required")
if not ENDPOINT:
    fail("BRAZE_REST_ENDPOINT env var is required (e.g. https://rest.iad-05.braze.com)")


# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------

SESSION = requests.Session()
SESSION.headers.update({
    "Authorization": f"Bearer {API_KEY}",
    "Content-Type": "application/json",
})


def get(path: str, params: dict[str, Any] | None = None, retries: int = 3) -> dict[str, Any]:
    url = f"{ENDPOINT}{path}"
    for attempt in range(1, retries + 1):
        resp = SESSION.get(url, params=params, timeout=30)
        if resp.status_code == 429:
            wait = int(resp.headers.get("Retry-After", "5"))
            print(f"  rate-limited, sleeping {wait}s", file=sys.stderr)
            time.sleep(wait)
            continue
        if 500 <= resp.status_code < 600:
            print(f"  server {resp.status_code}, retry {attempt}/{retries}", file=sys.stderr)
            time.sleep(2 ** attempt)
            continue
        if not resp.ok:
            fail(f"GET {path} -> {resp.status_code} {resp.text[:500]}")
        time.sleep(SLEEP_BETWEEN_CALLS)
        return resp.json()
    fail(f"GET {path} failed after {retries} retries")
    return {}


def list_canvases() -> list[dict]:
    out, page = [], 0
    while True:
        d = get("/canvas/list", params={"page": page, "include_archived": "false"})
        b = d.get("canvases", [])
        if not b:
            break
        out.extend(b); page += 1
        if len(b) < 100:
            break
    return out


def list_campaigns() -> list[dict]:
    out, page = [], 0
    while True:
        d = get("/campaigns/list", params={"page": page, "include_archived": "false"})
        b = d.get("campaigns", [])
        if not b:
            break
        out.extend(b); page += 1
        if len(b) < 100:
            break
    return out


def get_canvas_details(cid: str) -> dict:
    return get("/canvas/details", params={"canvas_id": cid})


def get_campaign_details(cid: str) -> dict:
    return get("/campaigns/details", params={"campaign_id": cid})


def get_canvas_data_series(cid: str, ending_at: str, length: int) -> dict:
    return get("/canvas/data_series", params={
        "canvas_id": cid, "ending_at": ending_at, "length": length,
        "include_step_breakdown": "true", "include_variant_breakdown": "true",
    })


def get_campaign_data_series(cid: str, ending_at: str, length: int) -> dict:
    return get("/campaigns/data_series", params={
        "campaign_id": cid, "ending_at": ending_at, "length": length,
    })


# ---------------------------------------------------------------------------
# Flatten
# ---------------------------------------------------------------------------

UNIVERSAL = dict(
    sent=0, delivered=0, bounces=0, errors=0,
    revenue=0.0, conversions=0, unique_recipients=0, entries=0,
    opens=0, unique_opens=0, clicks=0, unique_clicks=0,
    unsubscribes=0, reported_spam=0, machine_open=0, machine_amp_open=0,
    direct_opens=0, total_opens_push=0, body_clicks=0,
    sent_to_carrier=0, sms_delivered=0, sms_rejected=0,
    sms_delivery_failed=0, sms_clicks=0, sms_opt_out=0, sms_help=0,
)


def empty_row(date, flow_id, flow_name, flow_type, step_id, step_name, channel, variant_id):
    return {
        "date": date, "flow_type": flow_type, "flow_id": flow_id, "flow_name": flow_name,
        "step_id": step_id, "step_name": step_name,
        "channel": channel, "variant_id": variant_id,
        **UNIVERSAL,
    }


def _populate(r: dict, channel: str, item: dict) -> None:
    if channel == "email":
        r["sent"] = int(item.get("sent") or 0)
        r["delivered"] = int(item.get("delivered") or 0)
        r["bounces"] = int(item.get("bounces") or 0)
        r["opens"] = int(item.get("opens") or 0)
        r["unique_opens"] = int(item.get("unique_opens") or 0)
        r["clicks"] = int(item.get("clicks") or 0)
        r["unique_clicks"] = int(item.get("unique_clicks") or 0)
        r["unsubscribes"] = int(item.get("unsubscribes") or 0)
        r["reported_spam"] = int(item.get("reported_spam") or 0)
        r["machine_open"] = int(item.get("machine_open") or 0)
        r["machine_amp_open"] = int(item.get("machine_amp_open") or 0)
    elif channel in ("ios_push", "android_push", "web_push"):
        r["sent"] = int(item.get("sent") or 0)
        r["bounces"] = int(item.get("bounces") or 0)
        r["direct_opens"] = int(item.get("direct_opens") or 0)
        r["total_opens_push"] = int(item.get("total_opens") or 0)
        r["body_clicks"] = int(item.get("body_clicks") or 0)
    elif channel == "sms":
        r["sent"] = int(item.get("sent") or 0)
        r["sent_to_carrier"] = int(item.get("sent_to_carrier") or 0)
        r["sms_delivered"] = int(item.get("delivered") or 0)
        r["sms_rejected"] = int(item.get("rejected") or 0)
        r["sms_delivery_failed"] = int(item.get("delivery_failed") or 0)
        r["sms_clicks"] = int(item.get("clicks") or 0)
        r["sms_opt_out"] = int(item.get("opt_out") or 0)
        r["sms_help"] = int(item.get("help") or 0)
    elif channel == "webhook":
        r["sent"] = int(item.get("sent") or 0)
        r["errors"] = int(item.get("errors") or 0)


def flatten_canvas(canvas_id: str, ds: dict) -> list[dict]:
    payload = ds.get("data", {})
    name = payload.get("name", canvas_id)
    rows = []
    for stat in payload.get("stats", []):
        date = stat.get("time", "")
        total = stat.get("total_stats", {}) or {}

        tr = empty_row(date, canvas_id, name, "canvas", "__total__",
                       "Canvas Total", "__total__", None)
        tr["revenue"] = float(total.get("revenue") or 0)
        tr["conversions"] = int(total.get("conversions") or 0)
        tr["entries"] = int(total.get("entries") or 0)
        rows.append(tr)

        for step_id, step in (stat.get("step_stats") or {}).items():
            step_name = step.get("name", step_id)
            messages = step.get("messages") or {}
            base_rev = float(step.get("revenue") or 0)
            base_conv = int(step.get("conversions") or 0)
            base_uniq = int(step.get("unique_recipients") or 0)

            if not any(messages.values()):
                r = empty_row(date, canvas_id, name, "canvas", step_id, step_name, "none", None)
                r["revenue"], r["conversions"], r["unique_recipients"] = base_rev, base_conv, base_uniq
                rows.append(r); continue

            for ch, items in messages.items():
                if not items:
                    continue
                for it in items:
                    r = empty_row(date, canvas_id, name, "canvas", step_id, step_name,
                                  ch, it.get("variation_api_id"))
                    r["revenue"], r["conversions"], r["unique_recipients"] = base_rev, base_conv, base_uniq
                    _populate(r, ch, it)
                    rows.append(r)
    return rows


def flatten_campaign(campaign_id: str, name: str, ds: dict) -> list[dict]:
    payload = ds.get("data", [])
    if isinstance(payload, dict):
        payload = payload.get("stats") or payload.get("data") or []
    rows = []
    SYN_STEP = f"{campaign_id}::msg"
    for stat in payload:
        date = stat.get("time", "")
        tr = empty_row(date, campaign_id, name, "campaign", "__total__",
                       "Campaign Total", "__total__", None)
        tr["revenue"] = float(stat.get("revenue") or 0)
        tr["conversions"] = int(stat.get("conversions") or 0)
        tr["unique_recipients"] = int(stat.get("unique_recipients") or 0)
        rows.append(tr)

        msgs = stat.get("messages") or stat.get("messaging_performance") or {}
        for ch, items in msgs.items():
            if not items: continue
            if isinstance(items, dict): items = [items]
            for it in items:
                r = empty_row(date, campaign_id, name, "campaign", SYN_STEP,
                              "Campaign Message", ch,
                              it.get("variation_api_id") or it.get("api_id"))
                _populate(r, ch, it)
                rows.append(r)
    return rows


# ---------------------------------------------------------------------------
# Window pull
# ---------------------------------------------------------------------------

def pull_canvas_window(cid: str, days: int) -> dict:
    end = datetime.now(timezone.utc).replace(hour=23, minute=59, second=59, microsecond=0)
    remaining = days
    all_stats, seen, name = [], set(), cid
    while remaining > 0:
        chunk = min(CANVAS_MAX_DAYS, remaining)
        ds = get_canvas_data_series(cid, end.strftime("%Y-%m-%dT%H:%M:%SZ"), chunk)
        payload = ds.get("data", {})
        name = payload.get("name", name)
        for s in payload.get("stats", []):
            d = s.get("time", "")
            if d and d not in seen:
                all_stats.append(s); seen.add(d)
        end -= timedelta(days=chunk); remaining -= chunk
    all_stats.sort(key=lambda s: s.get("time", ""))
    return {"data": {"name": name, "stats": all_stats}}


def pull_campaign_window(cid: str, days: int) -> dict:
    end = datetime.now(timezone.utc).replace(hour=23, minute=59, second=59, microsecond=0)
    chunk = min(CAMPAIGN_MAX_DAYS, days)
    return get_campaign_data_series(cid, end.strftime("%Y-%m-%dT%H:%M:%SZ"), chunk)


# ---------------------------------------------------------------------------
# SQLite
# ---------------------------------------------------------------------------

DDL = """
CREATE TABLE IF NOT EXISTS flows (
    flow_id TEXT, flow_type TEXT, name TEXT, description TEXT,
    enabled INTEGER, archived INTEGER, draft INTEGER, schedule_type TEXT,
    tags TEXT, teams TEXT, channels TEXT,
    created_at TEXT, updated_at TEXT, extracted_at TEXT,
    PRIMARY KEY (flow_id, flow_type)
);
CREATE TABLE IF NOT EXISTS flow_steps (
    step_id TEXT, flow_id TEXT, flow_type TEXT,
    step_name TEXT, step_type TEXT, channels TEXT, extracted_at TEXT,
    PRIMARY KEY (step_id, flow_id, flow_type)
);
CREATE TABLE IF NOT EXISTS message_metrics_daily (
    date TEXT, flow_id TEXT, flow_type TEXT, flow_name TEXT,
    step_id TEXT, step_name TEXT, channel TEXT, variant_id TEXT,
    sent INTEGER, delivered INTEGER, bounces INTEGER, errors INTEGER,
    revenue REAL, conversions INTEGER, unique_recipients INTEGER, entries INTEGER,
    opens INTEGER, unique_opens INTEGER, clicks INTEGER, unique_clicks INTEGER,
    unsubscribes INTEGER, reported_spam INTEGER, machine_open INTEGER, machine_amp_open INTEGER,
    direct_opens INTEGER, total_opens_push INTEGER, body_clicks INTEGER,
    sent_to_carrier INTEGER, sms_delivered INTEGER, sms_rejected INTEGER,
    sms_delivery_failed INTEGER, sms_clicks INTEGER, sms_opt_out INTEGER, sms_help INTEGER,
    PRIMARY KEY (date, flow_id, flow_type, step_id, channel, variant_id)
);
CREATE TABLE IF NOT EXISTS alerts (
    detected_at TEXT, flow_id TEXT, flow_type TEXT, flow_name TEXT,
    step_id TEXT, step_name TEXT, channel TEXT,
    rule TEXT, severity TEXT, metric TEXT,
    current_value REAL, baseline_value REAL, sample_size INTEGER, message TEXT,
    PRIMARY KEY (detected_at, flow_id, flow_type, step_id, channel, rule)
);
CREATE INDEX IF NOT EXISTS idx_metrics_flow_date ON message_metrics_daily(flow_id, flow_type, date);
CREATE INDEX IF NOT EXISTS idx_metrics_date ON message_metrics_daily(date);
CREATE INDEX IF NOT EXISTS idx_alerts_recent ON alerts(detected_at);
"""

METRIC_COLS = (
    "date,flow_id,flow_type,flow_name,step_id,step_name,channel,variant_id,"
    "sent,delivered,bounces,errors,revenue,conversions,unique_recipients,entries,"
    "opens,unique_opens,clicks,unique_clicks,unsubscribes,reported_spam,machine_open,machine_amp_open,"
    "direct_opens,total_opens_push,body_clicks,"
    "sent_to_carrier,sms_delivered,sms_rejected,sms_delivery_failed,sms_clicks,sms_opt_out,sms_help"
)
UPSERT_METRIC = (
    f"INSERT OR REPLACE INTO message_metrics_daily ({METRIC_COLS}) VALUES "
    f"({','.join('?' * len(METRIC_COLS.split(',')))})"
)


def init_db(p: Path) -> sqlite3.Connection:
    c = sqlite3.connect(p); c.executescript(DDL); c.commit(); return c


def upsert_flow(conn, fid, ftype, listing, details):
    now = datetime.now(timezone.utc).isoformat()
    conn.execute("INSERT OR REPLACE INTO flows VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?)", (
        fid, ftype,
        details.get("name") or listing.get("name") or fid,
        details.get("description") or "",
        int(bool(details.get("enabled", listing.get("enabled", False)))),
        int(bool(details.get("archived", listing.get("archived", False)))),
        int(bool(details.get("draft", listing.get("draft", False)))),
        details.get("schedule_type") or "",
        json.dumps(details.get("tags") or listing.get("tags") or []),
        json.dumps(details.get("teams") or []),
        json.dumps(details.get("channels") or []),
        details.get("created_at") or "",
        details.get("updated_at") or listing.get("last_edited") or "",
        now,
    ))
    if ftype == "canvas":
        for s in details.get("steps", []):
            conn.execute("INSERT OR REPLACE INTO flow_steps VALUES (?,?,?,?,?,?,?)", (
                s.get("id"), fid, ftype, s.get("name", ""), s.get("type", ""),
                json.dumps(s.get("channels") or []), now,
            ))
    else:
        conn.execute("INSERT OR REPLACE INTO flow_steps VALUES (?,?,?,?,?,?,?)", (
            f"{fid}::msg", fid, ftype, "Campaign Message", "message",
            json.dumps(details.get("channels") or listing.get("channels") or []), now,
        ))


def upsert_metrics(conn, rows: Iterable[dict]) -> int:
    cols = METRIC_COLS.split(",")
    n = 0
    for r in rows:
        conn.execute(UPSERT_METRIC, tuple(r.get(c) for c in cols))
        n += 1
    return n


def export_dashboard_json(conn, out: Path) -> None:
    cur = conn.cursor()
    cur.execute("SELECT flow_id, flow_type, name, channels FROM flows "
                "WHERE COALESCE(archived,0)=0 ORDER BY name")
    flows = []
    for fid, ftype, name, ch in cur.fetchall():
        c2 = conn.cursor()
        c2.execute("SELECT step_id, step_name, step_type, channels FROM flow_steps "
                   "WHERE flow_id=? AND flow_type=?", (fid, ftype))
        steps = [{"step_id": s, "step_name": sn, "step_type": st,
                  "channels": json.loads(c or "[]")} for s, sn, st, c in c2.fetchall()]
        flows.append({"flow_id": fid, "flow_type": ftype, "name": name,
                      "channels": json.loads(ch or "[]"), "steps": steps})

    cur.execute(f"SELECT {METRIC_COLS} FROM message_metrics_daily ORDER BY date DESC")
    cols = METRIC_COLS.split(",")
    rows = [dict(zip(cols, r)) for r in cur.fetchall()]

    cur.execute("SELECT detected_at, flow_id, flow_type, flow_name, step_id, step_name, "
                "channel, rule, severity, metric, current_value, baseline_value, "
                "sample_size, message FROM alerts ORDER BY detected_at DESC LIMIT 500")
    acols = ["detected_at","flow_id","flow_type","flow_name","step_id","step_name",
             "channel","rule","severity","metric","current_value","baseline_value",
             "sample_size","message"]
    alerts = [dict(zip(acols, r)) for r in cur.fetchall()]

    out.write_text(json.dumps({
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "endpoint": ENDPOINT,
        "days_pulled": DAYS,
        "flows": flows, "rows": rows, "alerts": alerts,
    }, indent=2))


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    db = OUT_DIR / "braze_metrics.db"
    js = OUT_DIR / "dashboard_data.json"
    conn = init_db(db)

    if not SKIP_CANVASES:
        print(f"[1/3] Listing Canvases ...", file=sys.stderr)
        canvases = list_canvases()
        if TAG_FILTER:
            canvases = [c for c in canvases if TAG_FILTER in (c.get("tags") or [])]
        print(f"      {len(canvases)} Canvas(es)", file=sys.stderr)
        for i, c in enumerate(canvases, 1):
            try:
                d = get_canvas_details(c["id"])
                upsert_flow(conn, c["id"], "canvas", c, d)
                ds = pull_canvas_window(c["id"], DAYS)
                rows = flatten_canvas(c["id"], ds)
                n = upsert_metrics(conn, rows); conn.commit()
                print(f"  Canvas [{i}/{len(canvases)}] {(d.get('name','?') or c['id'])[:55]:<55} {n}",
                      file=sys.stderr)
            except Exception as e:
                print(f"  Canvas [{i}/{len(canvases)}] FAILED {c.get('id','?')}: {e}", file=sys.stderr)

    if not SKIP_CAMPAIGNS:
        print(f"[2/3] Listing Campaigns ...", file=sys.stderr)
        campaigns = list_campaigns()
        if TAG_FILTER:
            campaigns = [c for c in campaigns if TAG_FILTER in (c.get("tags") or [])]
        print(f"      {len(campaigns)} Campaign(s)", file=sys.stderr)
        for i, c in enumerate(campaigns, 1):
            try:
                d = get_campaign_details(c["id"])
                upsert_flow(conn, c["id"], "campaign", c, d)
                ds = pull_campaign_window(c["id"], DAYS)
                name = d.get("name") or c.get("name") or c["id"]
                rows = flatten_campaign(c["id"], name, ds)
                n = upsert_metrics(conn, rows); conn.commit()
                print(f"  Campaign [{i}/{len(campaigns)}] {name[:53]:<53} {n}", file=sys.stderr)
            except Exception as e:
                print(f"  Campaign [{i}/{len(campaigns)}] FAILED {c.get('id','?')}: {e}", file=sys.stderr)

    print(f"[3/3] Exporting -> {js}", file=sys.stderr)
    export_dashboard_json(conn, js)
    conn.close()
    print(f"Done.\n  SQLite : {db}\n  JSON   : {js}")


if __name__ == "__main__":
    main()
